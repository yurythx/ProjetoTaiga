# =============================================================================
# TAIGA — Variáveis de Ambiente (Modo Local / sem proxy reverso)
#
# Copie este arquivo:  cp .env.example .env
# Edite os campos marcados com  <<< ALTERE ISSO
# =============================================================================

# -----------------------------------------------------------------------------
# DOMÍNIO / URL
#
# Use o IP da sua máquina na rede local (ex: 192.168.1.10).
# Não use "localhost" se outros dispositivos precisarem acessar.
# Não inclua porta aqui — as portas são configuradas no docker-compose.yml.
# -----------------------------------------------------------------------------
TAIGA_DOMAIN=192.168.0.181  # <<< ALTERE ISSO (IP da sua máquina)
TAIGA_SCHEME=http

# -----------------------------------------------------------------------------
# SEGURANÇA
#
# Gere uma chave segura com:
#   python -c "import secrets; print(secrets.token_hex(64))"
# -----------------------------------------------------------------------------
SECRET_KEY=change-me-to-a-very-long-random-secret-key-minimum-64-chars   # <<< ALTERE ISSO

# -----------------------------------------------------------------------------
# BANCO DE DADOS (PostgreSQL)
# -----------------------------------------------------------------------------
POSTGRES_DB=taiga
POSTGRES_USER=taiga
POSTGRES_PASSWORD=taiga_db_senha_forte_aqui    # <<< ALTERE ISSO

# -----------------------------------------------------------------------------
# BROKER DE MENSAGENS (RabbitMQ)
# -----------------------------------------------------------------------------
RABBITMQ_USER=taiga
RABBITMQ_PASS=taiga_rabbit_senha_forte_aqui    # <<< ALTERE ISSO
RABBITMQ_VHOST=taiga

# -----------------------------------------------------------------------------
# E-MAIL
#
# Em modo local, o backend "console" imprime os e-mails diretamente nos logs
# do container taiga-back. Não precisa configurar SMTP para testes locais.
# Para ver os e-mails: docker compose logs taiga-back
# -----------------------------------------------------------------------------
EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
DEFAULT_FROM_EMAIL=taiga@localhost
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
EMAIL_USE_TLS=False
EMAIL_USE_SSL=False

# -----------------------------------------------------------------------------
# TELEMETRIA
# Defina como "False" para desabilitar o envio de dados anônimos ao Taiga.io
# -----------------------------------------------------------------------------
ENABLE_TELEMETRY=True

# -----------------------------------------------------------------------------
# SUPERUSUÁRIO ADMINISTRADOR (criado automaticamente na primeira execução)
#
# O serviço "taiga-init" usa essas variáveis para criar o admin via script.
# Se o usuário já existir, o script ignora (seguro para re-execuções).
# -----------------------------------------------------------------------------
DJANGO_SUPERUSER_USERNAME=admin                     # <<< ALTERE ISSO
DJANGO_SUPERUSER_EMAIL=admin@seudominio.com         # <<< ALTERE ISSO
DJANGO_SUPERUSER_PASSWORD=Admin@Taiga2024!          # <<< ALTERE ISSO (senha forte!)
